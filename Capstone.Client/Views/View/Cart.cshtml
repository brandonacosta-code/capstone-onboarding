@{
	Layout = null;
}

<div id="cart-container" style="padding: 20px; max-width: 900px; margin: 0 auto;">

	<!-- Header -->
	<div style="background: linear-gradient(135deg, #2c3e50, #3d5a6b);
                padding: 40px;
                border-radius: 8px;
                margin-bottom: 30px;
                text-align: center;">
		<h1 style="color: white; font-size: 2em;">Cart</h1>
	</div>

	<!-- Cart Table -->
	<div style="background: white;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                padding: 30px;">

		<table style="width: 100%; border-collapse: collapse;">
			<thead>
				<tr style="border-bottom: 2px solid #eee; font-weight: bold;">
					<td style="padding: 10px;">Product Name</td>
					<td style="padding: 10px; text-align: right;">Amount $</td>
				</tr>
			</thead>
			<tbody id="cart-items-container"></tbody>
		</table>

		<!-- Totals -->
		<div style="margin-top: 20px; border-top: 2px solid #eee; padding-top: 20px;">
			<div style="display: flex; justify-content: space-between; padding: 5px 0;">
				<span>Sub - total</span>
				<span data-bind="text: subTotal"></span>
			</div>
			<div style="display: flex; justify-content: space-between; padding: 5px 0;">
				<span>Taxes (5%)</span>
				<span data-bind="text: tax"></span>
			</div>
			<div style="display: flex; justify-content: space-between; padding: 5px 0;">
				<span>Shipping</span>
				<span data-bind="text: shipping"></span>
			</div>
			<div style="display: flex; justify-content: space-between; padding: 5px 0; font-weight: bold;">
				<span>Total</span>
				<span data-bind="text: total"></span>
			</div>
		</div>

		<!-- Continue to payment -->
		<button onclick="cartVM_continueToPayment()"
				style="margin-top: 20px;
                       padding: 15px 30px;
                       background: #3d5a6b;
                       color: white;
                       border: none;
                       border-radius: 8px;
                       font-size: 16px;
                       cursor: pointer;">
			Continue to payment
		</button>
	</div>

	<!-- Back to products -->
	<a href="#/products"
	   style="display: inline-block;
              margin-top: 20px;
              color: #3d5a6b;
              text-decoration: none;">
		Back to products
	</a>
</div>